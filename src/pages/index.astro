                  {a.url ? (
                    <a href={a.url} class="appearance-event">{a.event}</a>
                  ) : (
                    <span class="appearance-event">{a.event}</span>
                  )}
                  {a.description && <span class="appearance-desc">{a.description}</span>}
                </span>
                <span class="appearance-location">{a.location}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      */}

      {/* Hidden until ready: Recent Papers + Recent Talks grid and CV link
      <div class="academic-grid">
        <div class="academic-col">
          <h3><a href="/papers" class="home-heading-link">Recent Papers</a></h3>
          <ul class="paper-list">
            {recentPapers.map((p) => (
              <li>
                {p.data.url || p.data.arxiv ? (
                  <a href={p.data.url || `https://arxiv.org/abs/${p.data.arxiv}`} class="paper-title">{p.data.title}</a>
                ) : (
                  <span class="paper-title">{p.data.title}</span>
                )}
                <div class="paper-venue">{p.data.venue}, {new Date(p.data.date).getFullYear()}</div>
              </li>
            ))}
          </ul>
          <a href="/papers" class="section-link">All papers &rarr;</a>
        </div>

        <div class="academic-col">
          <h3><a href="/talks" class="home-heading-link">Recent Talks</a></h3>
          <ul class="talk-list">
            {recentTalks.map((t) => (
              <li>
                <a href={`/talks/${t.id.replace(/(\/index)?\.md$/, '')}/`} class="talk-title">{t.data.title}</a>
                <div class="talk-venue">{t.latestVenue.name}, {new Date(t.latestVenue.date).getFullYear()}</div>
              </li>
            ))}
          </ul>
          <a href="/talks" class="section-link">All talks &rarr;</a>
        </div>
      </div>

      <a href="#" class="section-link cv-link">Curriculum Vitae (PDF) &rarr;</a>
      */}
    </section>

    <!-- ===== Writing ===== -->
    <section id="writing" class="home-section fade-in">
      <p class="section-eyebrow">Writing</p>
      <h2><a href="/posts" class="home-heading-link">Posts</a></h2>

      <ul class="blog-list">
        {recentBlog.map((post) => {
          const href = `/posts/${post.id.replace(/(\/index)?\.md$/, '')}/`;
          return (
            <li class={`blog-item ${post.resolvedImage ? 'has-thumb' : 'no-thumb'}`}>
              {post.resolvedImage && (
                <a href={href} class="blog-thumb-link">
                  <img
                    src={post.resolvedImage.src}
                    alt={post.data.title}
                    loading="lazy"
                    class="blog-thumb"
                  />
                </a>
              )}
              <div class="blog-body">
                <a href={href} class="blog-title">{post.data.title}</a>
                <span class="blog-date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                {post.data.description && <p class="blog-desc">{post.data.description}</p>}
              </div>
            </li>
          );
        })}
      </ul>

    </section>
  </main>

  <script>
    document.querySelectorAll('.inline-toggle').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (link as HTMLElement).dataset.target;
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        const isHidden = target.hidden;
        target.hidden = !isHidden;
        link.classList.toggle('expanded', isHidden);
      });
    });

    const fadeTargets = document.querySelectorAll('.fade-in');
    if ('IntersectionObserver' in window && fadeTargets.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
      );
      fadeTargets.forEach((el) => observer.observe(el));
    } else {
      fadeTargets.forEach((el) => el.classList.add('is-visible'));
    }
  </script>
</Layout>
