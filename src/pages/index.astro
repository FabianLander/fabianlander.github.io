---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { resolveEntryImage, type GlobResult } from '../utils/images';
import profilePic from '../assets/ProfilePic.png';
import '../styles/pages/home.css';
import allTrips from '../data/trips.json';

// ---- Software ----
const allSoftware = await getCollection('software');

// ---- Blog ----
const blogImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/blog/**/*.{png,jpg,jpeg,webp,svg,avif,PNG,JPG,JPEG,WEBP,SVG,AVIF}',
  { eager: true },
) as GlobResult;

const allBlog = await getCollection('blog');
const recentBlogRaw = allBlog
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const recentBlog = await Promise.all(
  recentBlogRaw.map(async (p) => {
    const image = p.data.image
      ? await resolveEntryImage(p.id, p.data.image, 'blog', blogImages, 200)
      : null;
    return { ...p, resolvedImage: image };
  }),
);

// ---- Papers ----
const allPapers = await getCollection('papers');
const recentPapers = allPapers
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .slice(0, 5);

// ---- Talks ----
const allTalks = await getCollection('talks');
const recentTalks = allTalks
  .filter((t) => t.data.venues.length > 0)
  .map((t) => {
    const latestVenue = t.data.venues.sort(
      (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
    )[0];
    return { ...t, latestVenue };
  })
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return new Date(b.latestVenue.date).getTime() - new Date(a.latestVenue.date).getTime();
  })
  .slice(0, 5);

// ---- Trips: upcoming vs past (use endDate so ongoing trips stay "upcoming") ----
const now = new Date();
const today = now.toISOString().slice(0, 10);
const upcoming = allTrips
  .filter((t) => (t.endDate ?? t.date) >= today)
  .sort((a, b) => a.date.localeCompare(b.date));
const pastTrips = allTrips
  .filter((t) => (t.endDate ?? t.date) < today)
  .sort((a, b) => b.date.localeCompare(a.date));

function formatDateRange(start: string, end?: string): string {
  const s = new Date(start + 'T00:00:00');
  if (!end) return s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  const e = new Date(end + 'T00:00:00');
  const sameMonth = s.getMonth() === e.getMonth() && s.getFullYear() === e.getFullYear();
  if (sameMonth) {
    return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.getDate()}`;
  }
  return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} – ${e.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}`;
}

// ---- Demos: 8 most recent ----
const demoImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/demos/**/*.{png,jpg,jpeg,webp,svg,avif,PNG,JPG,JPEG,WEBP,SVG,AVIF}',
  { eager: true },
) as GlobResult;

const allDemos = await getCollection('demos');
const sortedDemos = allDemos
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const recentDemos = await Promise.all(
  sortedDemos.map(async (d) => {
    const image = d.data.image
      ? await resolveEntryImage(d.id, d.data.image, 'demos', demoImages)
      : null;
    return { ...d, resolvedImage: image };
  }),
);

// ---- Graphics: 8 most recent ----
const graphicsImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/graphics/**/*.{png,jpg,jpeg,webp,svg,avif,PNG,JPG,JPEG,WEBP,SVG,AVIF}',
  { eager: true },
) as GlobResult;

const allGraphics = await getCollection('graphics');
const sortedGraphics = allGraphics
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const recentGraphics = await Promise.all(
  sortedGraphics.map(async (g) => {
    const image = await resolveEntryImage(g.id, g.data.image, 'graphics', graphicsImages);
    return { ...g, resolvedImage: image };
  }),
);
---

<Layout title="Fabian Lander">
  <main class="home-main">
    <section class="hero">
      <div class="hero-text">
        <h1>Fabian Lander</h1>
        <p class="hero-pronouns">he/him</p>
        <p>
          Hello! I'm a PhD student in geometry, groups and dynamics at the
          Max Planck Institute for Mathematics in the Sciences in Leipzig, Germany.
          This site contains some of my <a href="#code">code</a> and
          <a href="#writing">writing</a>. The rest is stuck in drafts.
        </p>
      </div>
      <Image
        src={profilePic}
        alt="Fabian Lander"
        width={480}
        class="hero-photo"
      />
    </section>

    {/* Hidden until populated: Illustration / Graphics section
    <section id="illustration" class="home-section">
      <div class="home-section-label">Illustration</div>
      <h2><a href="/graphics" class="home-heading-link">Graphics</a></h2>

      <div class="thumb-grid">
        {recentGraphics.map((g) => (
          <a href="/graphics" class="thumb-cell">
            {g.resolvedImage ? (
              <img src={g.resolvedImage.src} alt={g.data.title} loading="lazy" />
            ) : (
              <div class="placeholder"></div>
            )}
          </a>
        ))}
      </div>

      <a href="/graphics" class="see-more-bar">
        <span class="see-more-count">Showing {recentGraphics.length} of {allGraphics.length} graphics</span>
        <span class="see-more-link">Browse all <span class="see-more-arrow">&rarr;</span></span>
      </a>
    </section>
    */}

    <!-- ===== Code ===== -->
    <section id="code" class="home-section fade-in">
      <p class="section-eyebrow">Interactive</p>
      <h2><a href="/demos" class="home-heading-link">Online Demos</a></h2>

      <div class="thumb-grid">
        {recentDemos.map((d) => (
          <a href={d.data.url} class="thumb-cell" target="_blank" rel="noopener">
            {d.resolvedImage ? (
              <img src={d.resolvedImage.src} alt={d.data.title} loading="lazy" />
            ) : (
              <div class="placeholder"></div>
            )}
          </a>
        ))}
      </div>

    </section>

    <!-- ===== Software ===== -->
    <section id="software" class="home-section fade-in">
      <p class="section-eyebrow">Code</p>
      <h2>Software</h2>

      <div class="software-list">
        {allSoftware.map((s) => (
          <div class="software-item">
            <h3>{s.data.github
              ? <a href={s.data.github} target="_blank" rel="noopener">{s.data.title}</a>
              : s.data.title}</h3>
            {s.data.description && <p class="software-desc">{s.data.description}</p>}
            <div class="software-meta">
              {s.data.tech}
              {s.data.tech && s.data.github && ' · '}
              {s.data.github && <a href={s.data.github} target="_blank" rel="noopener">GitHub</a>}
            </div>
            {s.data.seeAlso && (
              <p class="software-seealso">
                → <a href={s.data.seeAlso.url} target="_blank" rel="noopener">{s.data.seeAlso.label}</a>
              </p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- ===== Academic ===== -->
    <section class="home-section fade-in">
      <p class="section-eyebrow">Research</p>
      <p class="teaching-prose">
        I'm a PhD student of <strong><a href="https://sites.google.com/site/jamesfarremath/">James Farre</a></strong>, in the
        <a href="https://www.mis.mpg.de/de/geometry-groups-dynamics">Geometry, Groups, and Dynamics</a>
        research group (led by Anna Wienhard) and a member of the
        <a href="https://www.mis.mpg.de/lab">Mathematics Lab</a> at the
        <a href="https://www.mis.mpg.de/">MPI MiS in Leipzig</a>.
      </p>

      <p class="teaching-prose">
        The main thread of my research is moduli spaces of dilation structures on spheres, and the dynamics of their straight-line foliations. These are other things I currently work and think about:
      </p>

      <ul class="research-list">
        <li>with <strong><a href="https://math.dartmouth.edu/~doyle/">Peter Doyle</a></strong>, <strong><a href="https://www.math.brown.edu/reschwar/">Rich Schwartz</a></strong>, and <strong><a href="https://stevejtrettel.site/">Steve Trettel</a></strong>: proving that flat 8-vertex tori are universal, i.e. every modulus can be realized by an 8-vertex triangulation.</li>
        <li>with <strong><a href="https://stevejtrettel.site/">Steve Trettel</a></strong>: classification of surfaces of revolution in homogeneous 3-manifolds.</li>
        <li>with <strong><a href="https://charles-daly-math.github.io/">Charles Daly</a></strong>: symplectic tiling billiards on complete rational tori.</li>
        <li>as part of a team in the <a href="https://www.mis.mpg.de/lab">lab</a>: visualizing a class of aperiodic tilings of the hyperbolic plane, and developing an optimization library for (pseudo-)Riemannian geometry.</li>
        <li>with <strong><a href="https://sites.google.com/view/marit-bobbs-homepage">Marit Bobb</a></strong> and <strong><a href="https://stevejtrettel.site/">Steve Trettel</a></strong>: machine learning to study the space of embedded flat 8-vertex tori in ℝ³.</li>
        <li>computational rendering of polygonal representatives of dilation structures arising from meromorphic twisted 1-forms on low-complexity Riemann surfaces.</li>
      </ul>

