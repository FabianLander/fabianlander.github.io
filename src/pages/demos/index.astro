---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { resolveEntryImage, type GlobResult } from '../../utils/images';
import DemoCard from '../../components/DemoCard.astro';
import '../../styles/pages/demos.css';

const demoImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/demos/**/*.{png,jpg,jpeg,webp}',
  { eager: true },
) as GlobResult;

// Curated order first (lower `order` = earlier; entries without `order`
// fall to the end), then most recent first as a tiebreaker.
const allDemos = (await getCollection('demos')).sort((a, b) => {
  const oa = a.data.order ?? Infinity;
  const ob = b.data.order ?? Infinity;
  if (oa !== ob) return oa - ob;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const demos = await Promise.all(
  allDemos.map(async (d) => {
    const image = d.data.image
      ? await resolveEntryImage(d.id, d.data.image, 'demos', demoImages)
      : null;
    return { ...d, resolvedImage: image };
  }),
);
---

<Layout title="Online Demos — Fabian Lander">
  <main class="demos-page">
    <h1>Online Demos</h1>

    <div class="demos-grid">
      {demos.map((d) => (
        <DemoCard
          url={d.data.url}
          title={d.data.title}
          technique={d.data.technique}
          description={d.data.description}
          image={d.resolvedImage}
          featured={d.data.featured}
          subjects={d.data.subject}
        />
      ))}
    </div>

    {demos.length === 0 && (
      <p class="demos-empty">No demos yet.</p>
    )}
  </main>
</Layout>
