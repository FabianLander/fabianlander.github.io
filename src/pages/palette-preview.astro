---
// TEMPORARY palette comparison page — delete once a palette is chosen.
// View at /palette-preview on the dev server.
import profilePic from '../assets/ProfilePic.png';
import { Image } from 'astro:assets';

const palettes = [
  {
    name: '1 · Sage & Terracotta',
    blurb: 'Literal palette of the photo. Warm, botanical, lowest risk.',
    vars: {
      bg: '#F7F3E8', surface: '#E8E0D0', text: '#2B3330',
      heading: '#1A2422', accent: '#C0735C', accentHover: '#9C5946',
      muted: '#8B9A7B', border: '#DED6C4',
    },
  },
  {
    name: '2 · Teal & Clay',
    blurb: 'Cool teal as the brand color, clay as a spark. Cleaner, more designed.',
    vars: {
      bg: '#FBF8F2', surface: '#EFEADE', text: '#1F2E2E',
      heading: '#16201F', accent: '#2F6E6A', accentHover: '#235451',
      muted: '#D08A6E', border: '#E0D9CB',
    },
  },
  {
    name: '3 · Olive & Sand',
    blurb: 'Warm near-monochrome. Editorial. Lets the photo be the only color.',
    vars: {
      bg: '#F4EFE3', surface: '#E3DAC6', text: '#33301F',
      heading: '#26240F', accent: '#6B7140', accentHover: '#525636',
      muted: '#B2A68D', border: '#DBD1BB',
    },
  },
  {
    name: '4 · Dusty Teal & Gold',
    blurb: 'Two contrasting accents. The most "fun and modern" of the set.',
    vars: {
      bg: '#F6F4EC', surface: '#E9E5D7', text: '#24323A',
      heading: '#182329', accent: '#3C7E92', accentHover: '#2E6373',
      muted: '#C9A14A', border: '#DCD7C6',
    },
  },
  {
    name: '5 · Stone & Ember (dark)',
    blurb: 'Dark-first. Moody, portfolio-forward. Photo pops hard.',
    dark: true,
    vars: {
      bg: '#1B2625', surface: '#26302E', text: '#D7D2C6',
      heading: '#ECE6D8', accent: '#D88A6E', accentHover: '#E6A488',
      muted: '#9DBA94', border: '#34403D',
    },
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Palette Preview — Fabian Lander</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=JetBrains+Mono&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Source Serif 4', Georgia, serif;
      background: #2a2a2a;
      color: #ddd;
      padding: 2rem;
    }
    .page-head {
      max-width: 70rem; margin: 0 auto 2rem;
      font-family: 'IBM Plex Sans', sans-serif;
    }
    .page-head h1 { font-size: 1.6rem; margin-bottom: .4rem; }
    .page-head p { color: #999; font-size: .95rem; }

    .grid {
      max-width: 70rem; margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    /* ----- one palette mockup ----- */
    .mock {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.08);
      background: var(--bg);
      color: var(--text);
      display: flex; flex-direction: column;
    }
    .mock-label {
      font-family: 'IBM Plex Sans', sans-serif;
      background: rgba(0,0,0,.04);
      padding: .55rem .9rem;
      font-size: .85rem; font-weight: 600;
      color: var(--heading);
      border-bottom: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: baseline; gap: .5rem;
    }
    .mock-label .swatches { display: flex; gap: 3px; }
    .mock-label .swatches i {
      width: 14px; height: 14px; border-radius: 3px; display: inline-block;
      border: 1px solid rgba(0,0,0,.12);
    }
    .mock-blurb {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: .78rem; color: var(--text); opacity: .7;
      padding: .5rem .9rem 0;
    }
    .mock-body { padding: 1.1rem .9rem 1.3rem; }

    /* mini nav */
    .nav {
      font-family: 'IBM Plex Sans', sans-serif;
      display: flex; gap: 1rem; align-items: center;
      font-size: .82rem; margin-bottom: 1.1rem;
    }
    .nav .brand { font-weight: 700; color: var(--heading); }
    .nav a { margin-left: auto; color: var(--text); opacity: .8; text-decoration: none; }
    .nav a + a { margin-left: .9rem; }
    .nav a.active { color: var(--accent); opacity: 1; font-weight: 600; }

    .hero { display: flex; gap: .9rem; align-items: center; margin-bottom: 1rem; }
    .hero img { width: 66px; height: 66px; border-radius: 50%; object-fit: cover; }
    .hero h2 {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 1.35rem; font-weight: 700; color: var(--heading);
      letter-spacing: -.02em; line-height: 1.15;
    }
    .hero .role { font-size: .85rem; color: var(--accent); font-weight: 600;
      font-family: 'IBM Plex Sans', sans-serif; }

    .mock p { font-size: .92rem; line-height: 1.6; margin-bottom: .8rem; }
    .mock a.inline { color: var(--accent); text-decoration: underline;
      text-underline-offset: 2px; }
    .mock code {
      font-family: 'JetBrains Mono', monospace; font-size: .82em;
      background: var(--surface); color: var(--text);
      padding: .1em .4em; border-radius: 3px;
    }

    .btn {
      font-family: 'IBM Plex Sans', sans-serif;
      display: inline-block; font-size: .82rem; font-weight: 600;
      background: var(--accent); color: var(--bg);
      padding: .45rem .9rem; border-radius: 6px; text-decoration: none;
      margin-top: .3rem;
    }
    .btn.ghost {
      background: transparent; color: var(--accent);
      border: 1px solid var(--accent); margin-left: .5rem;
    }

    .card {
      margin-top: 1.1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px; padding: .8rem .9rem;
    }
    .card h3 {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: .92rem; color: var(--heading); margin-bottom: .25rem;
    }
    .card .tag {
      display: inline-block; font-family: 'IBM Plex Sans', sans-serif;
      font-size: .68rem; font-weight: 600;
      background: var(--muted); color: var(--bg);
      padding: .12em .5em; border-radius: 99px; margin-top: .4rem;
    }
    .card p { font-size: .82rem; opacity: .85; margin: 0; }
  </style>
</head>
<body>
  <div class="page-head">
    <h1>Palette comparison</h1>
    <p>Five directions, each rendered as a mini-homepage with the real photo. Pick one and I'll wire it into the actual tokens, then delete this page.</p>
  </div>

  <div class="grid">
    {palettes.map((pal) => (
      <div
        class="mock"
        style={`--bg:${pal.vars.bg};--surface:${pal.vars.surface};--text:${pal.vars.text};--heading:${pal.vars.heading};--accent:${pal.vars.accent};--accent-hover:${pal.vars.accentHover};--muted:${pal.vars.muted};--border:${pal.vars.border};`}
      >
        <div class="mock-label">
          <span>{pal.name}</span>
          <span class="swatches">
            <i style={`background:${pal.vars.bg}`}></i>
            <i style={`background:${pal.vars.accent}`}></i>
            <i style={`background:${pal.vars.muted}`}></i>
            <i style={`background:${pal.vars.text}`}></i>
          </span>
        </div>
        <div class="mock-blurb">{pal.blurb}</div>
        <div class="mock-body">
          <div class="nav">
            <span class="brand">FL</span>
            <a class="active">Research</a>
            <a>Blog</a>
            <a>Now</a>
          </div>

          <div class="hero">
            <Image src={profilePic} alt="profile" width={132} height={132} />
            <div>
              <h2>Fabian Lander</h2>
              <span class="role">Mathematician</span>
            </div>
          </div>

          <p>
            PhD student working on flat and affine surfaces, billiards, and
            mathematical visualization. Read about a <a class="inline" href="#">recent project</a> or
            browse the <code>demos</code>.
          </p>

          <a class="btn" href="#">View research</a>
          <a class="btn ghost" href="#">Blog</a>

          <div class="card">
            <h3>Geodesics on quadrics</h3>
            <p>An interactive look at closed geodesics.</p>
            <span class="tag">demo</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</body>
</html>
