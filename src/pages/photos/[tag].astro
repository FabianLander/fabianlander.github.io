---
import Layout from '../../layouts/Layout.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { getAllTrips, getNavData, buildGallery } from '../../utils/photos';
import { type GlobResult } from '../../utils/images';
import '../../styles/pages/photos.css';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/photos/**/*.{png,jpg,jpeg,webp}',
  { eager: true },
) as GlobResult;

export async function getStaticPaths() {
  const allTrips = await getAllTrips();
  const nav = getNavData(allTrips);

  const byTag: Record<string, typeof allTrips> = {};
  for (const trip of allTrips) {
    for (const tag of trip.data.tags) {
      if (!byTag[tag]) byTag[tag] = [];
      byTag[tag].push(trip);
    }
  }

  return Object.entries(byTag).map(([tag, trips]) => ({
    params: { tag },
    props: { tag, trips, ...nav },
  }));
}

const { tag, trips, years, yearCounts, tags, tagCounts } = Astro.props;
const { galleryItems, lightboxData } = await buildGallery(trips, allImages);

const label = tag.charAt(0).toUpperCase() + tag.slice(1).replace(/-/g, ' ');
---

<Layout title={`Photos — ${label} — Fabian Lander`}>
  <PhotoGallery
    title="Photos"
    subtitle={`${lightboxData.length} photos from ${trips.length} trips — ${label}`}
    years={years}
    yearCounts={yearCounts}
    tags={tags}
    tagCounts={tagCounts}
    activeTag={tag}
    galleryItems={galleryItems}
    lightboxData={lightboxData}
  />
</Layout>
