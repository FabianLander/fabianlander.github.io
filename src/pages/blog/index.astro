---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/pages/blog.css';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const slug = (id: string) => id.replace(/(\/index)?\.md$/, '') + '/';
---

<Layout title="Blog — Fabian Lander" description="Blog posts by Fabian Lander">
  <main class="blog-page">
    <header class="blog-page-header">
      <h1>Blog</h1>
    </header>

    <ul class="blog-page-list">
      {posts.map((post) => (
        <li class="blog-page-item">
          <a href={`/blog/${slug(post.id)}`} class="blog-page-title">{post.data.title}</a>
          <div class="blog-page-meta">
            <time class="blog-page-date" datetime={post.data.date.toISOString()}>
              {new Date(post.data.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
                timeZone: 'UTC',
              })}
            </time>
            {post.data.subject.length > 0 && (
              <div class="blog-page-subjects">
                {post.data.subject.map((s: string) => (
                  <span class="blog-page-subject">{s}</span>
                ))}
              </div>
            )}
          </div>
          {post.data.description && (
            <p class="blog-page-desc">{post.data.description}</p>
          )}
          {post.data.draft && (
            <span class="blog-page-draft">Draft</span>
          )}
        </li>
      ))}
    </ul>
  </main>
</Layout>
